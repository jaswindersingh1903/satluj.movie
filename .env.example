# Copy to .env.local (git-ignored) and fill in real values.
# For production, set the same NEXT_PUBLIC_* variables in the Cloudflare
# dashboard so they get baked into the static build.

# Optional — used only if you switch back to Cloudflare Stream for delivery.
NEXT_PUBLIC_STREAM_VIDEO_ID=

# Supabase — required for reactions, comments, and analytics sync.
# Get these from Supabase → Project Settings → API.
# Both values are meant to be public; security is enforced by RLS policies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
